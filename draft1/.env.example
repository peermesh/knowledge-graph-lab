# Knowledge Graph Lab - Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://kgl_user:kgl_password@localhost:5432/kgl_database
POSTGRES_DB=kgl_database
POSTGRES_USER=kgl_user
POSTGRES_PASSWORD=kgl_password

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Vector Database (Qdrant)
# ===========================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=kgl_knowledge

# ===========================================
# AI/ML API Keys
# ===========================================
# OpenAI API Key for GPT models
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key for Claude models  
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Perplexity API Key for research
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ===========================================
# Service Configuration
# ===========================================
DEBUG=true
NODE_ENV=development

# Service URLs (for inter-service communication)
INGESTION_SERVICE_URL=http://localhost:8001
KNOWLEDGE_GRAPH_SERVICE_URL=http://localhost:8002
REASONING_SERVICE_URL=http://localhost:8003

# Frontend URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_INGESTION_API=http://localhost:8001
NEXT_PUBLIC_KNOWLEDGE_API=http://localhost:8002
NEXT_PUBLIC_REASONING_API=http://localhost:8003

# ===========================================
# Content Generation Settings
# ===========================================
DEFAULT_MODEL=gpt-4
FALLBACK_MODEL=gpt-3.5-turbo
CONTENT_TEMPERATURE=0.7

# ===========================================
# Security Settings
# ===========================================
JWT_SECRET=your_jwt_secret_here
API_RATE_LIMIT=1000

# ===========================================
# Research Configuration
# ===========================================
MAX_RESEARCH_DEPTH=3
RESEARCH_BATCH_SIZE=5
MAX_CONCURRENT_REQUESTS=3

# ===========================================
# Email Configuration (Optional)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@kgl.dev

# ===========================================
# Geographic Scope
# ===========================================
DEFAULT_LOCATIONS=["Boulder, CO", "Colorado", "United States"]

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here